<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartmarket.infrastructure.dao.IUserTagDao">

    <resultMap id="dataMap" type="com.smartmarket.infrastructure.dao.po.UserTag">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="tag_code" property="tagCode"/>
        <result column="risk_level" property="riskLevel"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryUserTag" parameterType="java.lang.String" resultMap="dataMap">
        select id, user_id, tag_code, risk_level, create_time, update_time
        from user_tag
        where user_id = #{userId}
        limit 1
    </select>

</mapper>
